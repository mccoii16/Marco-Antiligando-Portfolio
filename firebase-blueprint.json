{
  "entities": {
    "GalleryItem": {
      "title": "Gallery Item",
      "description": "A project or photo/video in the portfolio gallery",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string", "description": "URL of the project media" },
        "type": { "type": "string", "enum": ["image", "video"], "description": "Type of media" },
        "title": { "type": "string", "description": "Title of the project" },
        "description": { "type": "string", "description": "Short description of the project" },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorUid": { "type": "string" }
      },
      "required": ["url", "type", "createdAt", "authorUid"]
    }
  },
  "firestore": {
    "/gallery": {
      "schema": "GalleryItem",
      "description": "Collection of portfolio gallery items"
    }
  }
}
